{
  "name": "notebook-llm-mini",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.your.aiapp",
    "asar": true,
    "files": [
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asirihewage/notebook-llm-mini.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/asirihewage/notebook-llm-mini/issues"
  },
  "homepage": "https://github.com/asirihewage/notebook-llm-mini#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "node-llama-cpp": "^3.17.1"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2"
  }
}
